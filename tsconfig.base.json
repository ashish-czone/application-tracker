{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "paths": {
      "@packages/entity-engine": ["./packages/platform/entity-engine/api"],
      "@packages/entity-engine/*": ["./packages/platform/entity-engine/api/*"],
      "@packages/entity-engine-ui": ["./packages/platform/entity-engine/ui"],
      "@packages/entity-engine-ui/*": ["./packages/platform/entity-engine/ui/*"],
      "@packages/entity-engine-contract": ["./packages/platform/entity-engine/contracts"],
      "@packages/entity-engine-contract/*": ["./packages/platform/entity-engine/contracts/*"],
      "@packages/notification-channels": ["./packages/platform/notification-channels/api"],
      "@packages/notification-channels/*": ["./packages/platform/notification-channels/api/*"],
      "@packages/notification-channels-ui": ["./packages/platform/notification-channels/ui"],
      "@packages/notification-channels-ui/*": ["./packages/platform/notification-channels/ui/*"],
      "@packages/audit": ["./packages/platform/audit/api"],
      "@packages/audit/*": ["./packages/platform/audit/api/*"],
      "@packages/auth": ["./packages/platform/auth/api"],
      "@packages/auth/*": ["./packages/platform/auth/api/*"],
      "@packages/automations": ["./packages/platform/automations/api"],
      "@packages/automations/*": ["./packages/platform/automations/api/*"],
      "@packages/notifications": ["./packages/platform/notifications/api"],
      "@packages/notifications/*": ["./packages/platform/notifications/api/*"],
      "@packages/queue": ["./packages/platform/queue/api"],
      "@packages/queue/*": ["./packages/platform/queue/api/*"],
      "@packages/rbac": ["./packages/platform/rbac/api"],
      "@packages/rbac/*": ["./packages/platform/rbac/api/*"],
      "@packages/settings": ["./packages/platform/settings/api"],
      "@packages/settings/*": ["./packages/platform/settings/api/*"],
      "@packages/users": ["./packages/platform/users/api"],
      "@packages/users/*": ["./packages/platform/users/api/*"],
      "@packages/workflows": ["./packages/platform/workflows/api"],
      "@packages/workflows/*": ["./packages/platform/workflows/api/*"],
      "@packages/org-units": ["./packages/addons/org-units/api"],
      "@packages/org-units/*": ["./packages/addons/org-units/api/*"],
      "@packages/tasks-contract": ["./packages/addons/tasks/contracts"],
      "@packages/tasks-contract/*": ["./packages/addons/tasks/contracts/*"],
      "@packages/taxonomy": ["./packages/platform/taxonomy/api"],
      "@packages/taxonomy/*": ["./packages/platform/taxonomy/api/*"],
      "@packages/taxonomy-ui": ["./packages/platform/taxonomy/ui"],
      "@packages/taxonomy-ui/*": ["./packages/platform/taxonomy/ui/*"],
      "@packages/audit-ui": ["./packages/platform/audit/ui"],
      "@packages/audit-ui/*": ["./packages/platform/audit/ui/*"],
      "@packages/auth-ui": ["./packages/platform/auth/ui"],
      "@packages/auth-ui/*": ["./packages/platform/auth/ui/*"],
      "@packages/automations-ui": ["./packages/platform/automations/ui"],
      "@packages/automations-ui/*": ["./packages/platform/automations/ui/*"],
      "@packages/notifications-ui": ["./packages/platform/notifications/ui"],
      "@packages/notifications-ui/*": ["./packages/platform/notifications/ui/*"],
      "@packages/queue-ui": ["./packages/platform/queue/ui"],
      "@packages/queue-ui/*": ["./packages/platform/queue/ui/*"],
      "@packages/rbac-ui": ["./packages/platform/rbac/ui"],
      "@packages/rbac-ui/*": ["./packages/platform/rbac/ui/*"],
      "@packages/settings-ui": ["./packages/platform/settings/ui"],
      "@packages/settings-ui/*": ["./packages/platform/settings/ui/*"],
      "@packages/users-ui": ["./packages/platform/users/ui"],
      "@packages/users-ui/*": ["./packages/platform/users/ui/*"],
      "@packages/workflows-ui": ["./packages/platform/workflows/ui"],
      "@packages/workflows-ui/*": ["./packages/platform/workflows/ui/*"],
      "@packages/org-units-ui": ["./packages/addons/org-units/ui"],
      "@packages/org-units-ui/*": ["./packages/addons/org-units/ui/*"],
      "@packages/notes": ["./packages/addons/notes/api"],
      "@packages/notes/*": ["./packages/addons/notes/api/*"],
      "@packages/notes-ui": ["./packages/addons/notes/ui"],
      "@packages/notes-ui/*": ["./packages/addons/notes/ui/*"],
      "@packages/evaluations": ["./packages/addons/evaluations/api"],
      "@packages/evaluations/*": ["./packages/addons/evaluations/api/*"],
      "@packages/evaluations-ui": ["./packages/addons/evaluations/ui"],
      "@packages/evaluations-ui/*": ["./packages/addons/evaluations/ui/*"],
      "@packages/entity-relations": ["./packages/addons/entity-relations/api"],
      "@packages/entity-relations/*": ["./packages/addons/entity-relations/api/*"],
      "@packages/entity-relations-ui": ["./packages/addons/entity-relations/ui"],
      "@packages/entity-relations-ui/*": ["./packages/addons/entity-relations/ui/*"],
      "@packages/document-templates": ["./packages/addons/document-templates/api"],
      "@packages/document-templates/*": ["./packages/addons/document-templates/api/*"],
      "@packages/document-templates-ui": ["./packages/addons/document-templates/ui"],
      "@packages/document-templates-ui/*": ["./packages/addons/document-templates/ui/*"],
      "@packages/attachments": ["./packages/addons/attachments/api"],
      "@packages/attachments/*": ["./packages/addons/attachments/api/*"],
      "@packages/attachments-ui": ["./packages/addons/attachments/ui"],
      "@packages/attachments-ui/*": ["./packages/addons/attachments/ui/*"],
      "@packages/app-shell": ["./packages/platform/app-shell/api"],
      "@packages/app-shell/*": ["./packages/platform/app-shell/api/*"],
      "@packages/app-shell-ui": ["./packages/platform/app-shell/ui"],
      "@packages/app-shell-ui/*": ["./packages/platform/app-shell/ui/*"],
      "@packages/address": ["./packages/platform/address/api"],
      "@packages/address/*": ["./packages/platform/address/api/*"],
      "@packages/address-ui": ["./packages/platform/address/ui"],
      "@packages/address-ui/*": ["./packages/platform/address/ui/*"],
      "@packages/hierarchy": ["./packages/platform/hierarchy/api"],
      "@packages/hierarchy/*": ["./packages/platform/hierarchy/api/*"],
      "@packages/hierarchy-ui": ["./packages/platform/hierarchy/ui"],
      "@packages/hierarchy-ui/*": ["./packages/platform/hierarchy/ui/*"],
      "@packages/orderable": ["./packages/platform/orderable/api"],
      "@packages/orderable/*": ["./packages/platform/orderable/api/*"],
      "@packages/menus-api": ["./packages/addons/menus/api"],
      "@packages/menus-api/*": ["./packages/addons/menus/api/*"],
      "@domains/agency-contract": ["./domains/agency/contract"],
      "@domains/agency-contract/*": ["./domains/agency/contract/*"],
      "@domains/agency-ui": ["./domains/agency/ui"],
      "@domains/agency-ui/*": ["./domains/agency/ui/*"],
      "@packages/*": ["./packages/core/*", "./packages/platform/*", "./packages/addons/*"],
      "@domains/*": ["./domains/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
