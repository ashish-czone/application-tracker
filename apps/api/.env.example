DATABASE_URL=postgresql://dev:dev@localhost:5432/starter
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-user-secret
ALLOWED_ORIGINS=http://localhost:5173
NODE_ENV=development
API_ENABLED=true
WORKER_ENABLED=true

# Notification channel providers (defaults to 'console' for dev)
# EMAIL_PROVIDER=console
# WHATSAPP_PROVIDER=console

# SMTP Email (required when EMAIL_PROVIDER=smtp)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# Twilio WhatsApp (required when WHATSAPP_PROVIDER=twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=+14155238886
