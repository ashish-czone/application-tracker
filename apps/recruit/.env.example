DATABASE_URL=postgresql://dev:dev@localhost:5432/recruit
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-recruit-secret
ALLOWED_ORIGINS=http://localhost:5175
NODE_ENV=development
PORT=3011

# Media (local or s3)
# MEDIA_PROVIDER=local
# MEDIA_LOCAL_PATH=./uploads
# MEDIA_BASE_URL=http://localhost:3011/uploads

# Multi-tenancy (optional — omit TENANCY_MODE for single-tenant)
# TENANCY_MODE=database
# TENANCY_RESOLVER=header
# TENANCY_HEADER=x-tenant-id
# CONTROL_PLANE_URL=http://localhost:3013/api/v1
# SERVICE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# TRUSTED_SERVICE_KEYS={"control-plane":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}

# Debug profiler — dev only. Emits X-Debug-Timing header per request and
# appends a `_debug` block to JSON responses when ?debug=1 is set.
# DEBUG_PROFILING=true
