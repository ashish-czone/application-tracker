DATABASE_URL=postgresql://dev:dev@localhost:5432/control_plane
REDIS_URL=redis://localhost:6379
# BullMQ key prefix. Required when multiple apps share a single Redis
# instance, otherwise their Workers race for jobs over the shared queue
# names and silently consume each other's payloads.
BULL_QUEUE_PREFIX=bull:control-plane
JWT_SECRET=change-me-cp-secret
ALLOWED_ORIGINS=http://localhost:5180
NODE_ENV=development
PORT=3013

# Service-to-service auth (required)
# Generate key pair: openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
# Extract public key: openssl rsa -in private.pem -pubout -out public.pem
SERVICE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
TRUSTED_SERVICE_KEYS={"recruit-app":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}

# Tenant provisioning (used by subscription activation listener)
# {slug} is replaced with the tenant slug, {db_name} with tenant_<slug_underscored>
TENANT_DB_URL_TEMPLATE=postgresql://dev:dev@localhost:5432/{db_name}
