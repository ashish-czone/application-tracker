DATABASE_URL=postgresql://dev:dev@localhost:5432/control_plane
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-cp-secret
ALLOWED_ORIGINS=http://localhost:5180
NODE_ENV=development
PORT=3013

# Service-to-service auth (required)
# Generate key pair: openssl genpkey -algorithm RSA -out private.pem -pkeyopt rsa_keygen_bits:2048
# Extract public key: openssl rsa -in private.pem -pubout -out public.pem
SERVICE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
TRUSTED_SERVICE_KEYS={"recruit-app":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}
