{
  "name": "@apps/agency",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "dev:debug": "nest start --debug --watch",
    "start": "node dist/main",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "db:migrate": "tsx src/cli/migrate.ts",
    "db:seed:system": "nest build && node --env-file=.env dist/cli/seed.js --kind=system",
    "db:seed:demo": "nest build && node --env-file=.env dist/cli/seed.js --kind=demo"
  },
