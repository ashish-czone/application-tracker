    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.4.0",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.0",
    "@packages/app-shell": "workspace:*",
    "@packages/audit": "workspace:*",
    "@packages/auth": "workspace:*",
    "@packages/automations": "workspace:*",
    "@packages/common": "workspace:*",
