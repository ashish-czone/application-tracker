{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@modules/*": ["src/modules/*"],
      "@packages/platform-ui-taxonomy": ["../../packages/platform/platform-ui/taxonomy"],
      "@packages/platform-ui-taxonomy/*": ["../../packages/platform/platform-ui/taxonomy/*"],
      "@packages/platform-ui-conditions": ["../../packages/platform/platform-ui/conditions"],
      "@packages/platform-ui-conditions/*": ["../../packages/platform/platform-ui/conditions/*"],
      "@packages/*": ["../../packages/core/*", "../../packages/platform/*", "../../packages/addons/*"]
    },
    "noEmit": true
  },
  "include": ["src"]
}
