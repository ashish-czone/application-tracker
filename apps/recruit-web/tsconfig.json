{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@modules/*": ["src/modules/*"],
      "@packages/platform-ui-taxonomy": ["../../packages/platform/platform-ui/taxonomy"],
      "@packages/platform-ui-taxonomy/*": ["../../packages/platform/platform-ui/taxonomy/*"],
      "@packages/platform-ui-conditions": ["../../packages/platform/platform-ui/conditions"],
      "@packages/platform-ui-conditions/*": ["../../packages/platform/platform-ui/conditions/*"],
      "@packages/entity-engine": ["../../packages/platform/entity-engine/backend"],
      "@packages/entity-engine/*": ["../../packages/platform/entity-engine/backend/*"],
      "@packages/entity-engine-ui": ["../../packages/platform/entity-engine/ui"],
      "@packages/entity-engine-ui/*": ["../../packages/platform/entity-engine/ui/*"],
      "@packages/notification-channels": ["../../packages/platform/notification-channels/backend"],
      "@packages/notification-channels/*": ["../../packages/platform/notification-channels/backend/*"],
      "@packages/notification-channels-ui": ["../../packages/platform/notification-channels/ui"],
      "@packages/notification-channels-ui/*": ["../../packages/platform/notification-channels/ui/*"],
      "@packages/*": ["../../packages/core/*", "../../packages/platform/*", "../../packages/addons/*"],
      "@domains/recruit-backend": ["../../domains/recruit/backend"],
      "@domains/recruit-backend/*": ["../../domains/recruit/backend/*"],
      "@domains/recruit-web": ["../../domains/recruit/web"],
      "@domains/recruit-web/*": ["../../domains/recruit/web/*"]
    },
    "noEmit": true
  },
  "include": ["src"]
}
