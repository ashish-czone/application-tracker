DATABASE_URL=postgresql://dev:dev@localhost:5432/compliance
REDIS_URL=redis://localhost:6379
# BullMQ key prefix. Required when multiple apps share a single Redis
# instance, otherwise their Workers race for jobs over the shared queue
# names (e.g. `automation.execution`) and silently consume each other's
# payloads. Pick a unique value per app.
BULL_QUEUE_PREFIX=bull:compliance
JWT_SECRET=change-me-compliance-secret
ALLOWED_ORIGINS=http://localhost:5176
NODE_ENV=development
PORT=3012

# Media (local or s3)
# MEDIA_PROVIDER=local
# MEDIA_LOCAL_PATH=./uploads
# MEDIA_BASE_URL=http://localhost:3012/uploads

# Multi-tenancy (optional — omit TENANCY_MODE for single-tenant)
# TENANCY_MODE=database
# TENANCY_RESOLVER=header
# TENANCY_HEADER=x-tenant-id
# CONTROL_PLANE_URL=http://localhost:3013/api/v1
# SERVICE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# TRUSTED_SERVICE_KEYS={"control-plane":"-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"}

# Debug profiler — dev only. Emits X-Debug-Timing header per request and
# appends a `_debug` block to JSON responses when ?debug=1 is set.
# DEBUG_PROFILING=true

# Test hooks — e2e suite only. Mounts POST /admin/test/reset which truncates
# every data table and reruns the system + e2e-admin seeds. Positive opt-in
# (unset = endpoint not registered) so previews / staging cannot be reset
# accidentally.
# ENABLE_TEST_HOOKS=true
