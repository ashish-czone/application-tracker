{
  "name": "@packages/database",
  "version": "0.0.1",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "db:generate": "node scripts/collect-schemas.js && prisma generate",
    "db:migrate": "node scripts/collect-schemas.js && prisma migrate dev",
    "db:migrate:deploy": "node scripts/collect-schemas.js && prisma migrate deploy"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@prisma/client": "^6.5.0"
  },
  "prisma": {
    "schema": "prisma/schema"
  },
  "devDependencies": {
    "prisma": "^6.5.0",
    "typescript": "^5.7.0"
  }
}
