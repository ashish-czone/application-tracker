{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@packages/entity-engine-ui": ["../../entity-engine/ui"],
      "@packages/entity-engine-ui/*": ["../../entity-engine/ui/*"],
      "@packages/hierarchy": ["../"],
      "@packages/hierarchy/*": ["../*"],
      "@packages/hierarchy-ui": ["."],
      "@packages/hierarchy-ui/*": ["./*"],
      "@packages/*": ["../../../core/*/", "../../../platform/*/", "../../../addons/*/"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
