{
  "name": "starter-template",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "@dnd-kit/abstract": "0.1.21",
      "@dnd-kit/collision": "0.1.21",
      "@dnd-kit/dom": "0.1.21",
      "@dnd-kit/geometry": "0.1.21",
      "@dnd-kit/helpers": "0.1.18",
      "@dnd-kit/react": "0.1.18",
      "@dnd-kit/state": "0.1.21"
    }
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "pnpm lint:boundaries",
    "lint:boundaries": "eslint -c eslint.boundaries.config.mjs apps packages domains",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @packages/database db:generate",
    "db:migrate": "pnpm --filter @packages/database db:migrate",
    "db:push": "pnpm --filter @packages/database db:push",
    "db:studio": "pnpm --filter @packages/database db:studio",
    "gen:entity": "tsx --tsconfig tsconfig.base.json tools/gen-entity/index.ts"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.3.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@playwright/test": "^1.58.2",
    "@swc/core": "^1.15.18",
    "@types/cookie-parser": "^1.4.8",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.2",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "cookie-parser": "^1.4.7",
    "eslint": "^10.2.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "supertest": "^7.0.0",
    "tsx": "^4.20.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0",
    "unplugin-swc": "^1.5.9",
    "vitest": "^3.0.0"
  }
}
